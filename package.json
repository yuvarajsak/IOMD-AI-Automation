{
  "name": "iomd-ts-mobileautomation",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript Appium + Cucumber framework for iOS and Android execution with Gherkin-driven code generation.",
  "scripts": {
    "test:android": "wdio run ./wdio.android.conf.ts",
    "test:ios": "wdio run ./wdio.ios.conf.ts",
    "test:codegen:onboarding:android": "wdio run ./wdio.codegen.onboarding.android.conf.ts",
    "test:codegen:onboarding:ios": "wdio run ./wdio.codegen.onboarding.ios.conf.ts",
    "test:codegen:buyagain:ios": "wdio run ./wdio.codegen.buyagain.ios.conf.ts",
    "dryrun:codegen:buyagain": "node --import tsx ./scripts/dry-run-codegen-buyagain.ts",
    "test:legacy:buyagain:ios": "wdio run ./wdio.legacy.buyagain.ios.conf.ts",
    "report:allure:generate": "allure generate ./artifacts/allure-results --clean -o ./artifacts/allure-report",
    "report:allure:open": "allure open ./artifacts/allure-report",
    "generate:steps": "node --import tsx ./src/generator/gherkin-generator.ts",
    "migrate:features": "node --import tsx ./src/migration/migrate-features.ts",
    "migrate:locators": "node --import tsx ./src/migration/migrate-locators.ts",
    "migrate:steps-catalog": "node --import tsx ./src/migration/extract-java-steps.ts",
    "migrate:pages": "node --import tsx ./src/migration/generate-page-classes.ts",
    "dedupe:steps": "node --import tsx ./src/migration/dedupe-generated-steps.ts",
    "migrate:all": "node --import tsx ./src/migration/migrate-all.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cucumber/gherkin": "^28.0.0",
    "@cucumber/messages": "^25.0.0",
    "@types/node": "^24.5.2",
    "@wdio/appium-service": "^9.17.0",
    "@wdio/cli": "^9.17.0",
    "@wdio/cucumber-framework": "^9.17.0",
    "@wdio/globals": "^9.17.0",
    "@wdio/local-runner": "^9.17.0",
    "@wdio/spec-reporter": "^9.17.0",
    "appium": "^2.17.1",
    "dotenv": "^16.6.1",
    "expect-webdriverio": "^5.4.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "webdriverio": "^9.17.0"
  },
  "devDependencies": {
    "@wdio/allure-reporter": "^9.27.1",
    "allure-commandline": "^2.40.0",
    "appium-uiautomator2-driver": "^2.45.1",
    "appium-xcuitest-driver": "^5.16.1"
  }
}
